# Grok (xAI) API (required)
GROK_API_KEY=your_grok_api_key_here

# MongoDB (required)
MONGODB_URI=mongodb://localhost:27017/multi-agent

# Redis (optional — falls back to in-memory if not set)
REDIS_URL=redis://localhost:6379

# Pinecone (optional — long-term vector memory, disabled without embeddings)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=multi-agent-memory

# Brave Search API (optional — WebSearchTool uses DuckDuckGo if not set)
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# Auth (set to true to disable auth checks in development)
AUTH_DISABLED=true
